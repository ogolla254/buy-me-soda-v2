datasource db {
  provider = "sqlite"
  url      = "file:/app/data/dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String @id @default(uuid())
  name      String
  email     String @unique
  username  String @unique
  password  String
  paypalMe  String
  profilePicture String @default("")
  bio       String @default("")
  createdAt DateTime @default(now())
}